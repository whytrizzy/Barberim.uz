# PostgreSQL Database URL with connection pool timeout safeguards for Vercel (Supabase Transaction Pooler port 6543)
DATABASE_URL="postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=15&pool_timeout=15&sslmode=require"

# Direct Connection URL for Prisma CLI Migrations (Direct connection port 5432)
DIRECT_URL="postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?connect_timeout=15&sslmode=require"

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyz"

# Mini App Base URL (e.g. https://t.me/BarberimBot/app or web URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BOT_USERNAME="BarberimBot"
